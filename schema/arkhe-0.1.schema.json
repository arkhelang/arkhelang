{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkhelang.org/schema/arkhe-0.1.schema.json",
  "title": "Arkhe module (v0.1)",
  "description": "Structural schema for an Arkhe ontology module. Structural validity only; semantic rules (key references, link endpoints, guard compilation, state write paths, traversal depth) are enforced by the validator.",
  "type": "object",
  "required": [
    "module",
    "version",
    "arkhe",
    "entities"
  ],
  "additionalProperties": false,
  "properties": {
    "module": {
      "$ref": "#/$defs/moduleName"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "arkhe": {
      "type": "string",
      "const": "0.1",
      "description": "Spec version this module is written against."
    },
    "annotations": {
      "$ref": "#/$defs/annotations"
    },
    "imports": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "module",
          "version"
        ],
        "additionalProperties": false,
        "properties": {
          "module": {
            "$ref": "#/$defs/moduleName"
          },
          "version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
            "description": "Exact version pin of the imported module."
          }
        }
      }
    },
    "roles": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/memberName"
      },
      "additionalProperties": {
        "$ref": "#/$defs/role"
      }
    },
    "entities": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/typeName"
      },
      "additionalProperties": {
        "$ref": "#/$defs/entity"
      }
    },
    "links": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/memberName"
      },
      "additionalProperties": {
        "$ref": "#/$defs/link"
      }
    },
    "actions": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/memberName"
      },
      "additionalProperties": {
        "$ref": "#/$defs/action"
      }
    },
    "invariants": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/memberName"
      },
      "additionalProperties": {
        "$ref": "#/$defs/invariant"
      }
    }
  },
  "$defs": {
    "moduleName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "typeName": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]*$"
    },
    "memberName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "annotations": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Free-form string annotations. 'description' feeds generated docs and tool descriptions."
    },
    "celExpression": {
      "type": "string",
      "minLength": 1,
      "description": "A CEL expression in the Arkhe subset. Compiled and type-checked by the validator, not this schema."
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "$ref": "#/$defs/annotations"
        },
        "claims": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Identity-claim patterns this role binds to at compile time."
        }
      }
    },
    "scalarType": {
      "enum": [
        "string",
        "int",
        "number",
        "bool",
        "date",
        "datetime",
        "document"
      ]
    },
    "enumValue": {
      "type": [
        "string",
        "integer"
      ]
    },
    "property": {
      "type": "object",
      "required": [
        "type"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "anyOf": [
            {
              "$ref": "#/$defs/scalarType"
            },
            {
              "enum": [
                "enum",
                "state"
              ]
            }
          ]
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/enumValue"
          },
          "uniqueItems": true
        },
        "initial": {
          "$ref": "#/$defs/enumValue"
        },
        "optional": {
          "type": "boolean",
          "default": false
        },
        "annotations": {
          "$ref": "#/$defs/annotations"
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "const": "enum"
              }
            }
          },
          "then": {
            "required": [
              "values"
            ],
            "properties": {
              "initial": false
            }
          }
        },
        {
          "if": {
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "const": "state"
              }
            }
          },
          "then": {
            "required": [
              "values",
              "initial"
            ]
          }
        },
        {
          "if": {
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "not": {
                  "enum": [
                    "enum",
                    "state"
                  ]
                }
              }
            }
          },
          "then": {
            "properties": {
              "values": false,
              "initial": false
            }
          }
        }
      ]
    },
    "entity": {
      "type": "object",
      "required": [
        "keys",
        "properties"
      ],
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "$ref": "#/$defs/annotations"
        },
        "keys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/memberName"
          },
          "uniqueItems": true
        },
        "properties": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "$ref": "#/$defs/memberName"
          },
          "additionalProperties": {
            "$ref": "#/$defs/property"
          }
        }
      }
    },
    "link": {
      "type": "object",
      "required": [
        "from",
        "to",
        "cardinality"
      ],
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "$ref": "#/$defs/annotations"
        },
        "from": {
          "$ref": "#/$defs/typeName"
        },
        "to": {
          "$ref": "#/$defs/typeName"
        },
        "reverse": {
          "$ref": "#/$defs/memberName"
        },
        "cardinality": {
          "enum": [
            "one_to_one",
            "many_to_one",
            "one_to_many",
            "many_to_many"
          ]
        },
        "properties": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/memberName"
          },
          "additionalProperties": {
            "$ref": "#/$defs/dataProperty"
          }
        }
      }
    },
    "effect": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "propertyNames": {
        "type": "string",
        "pattern": "^target(\\.[a-z][a-z0-9_]*){1,2}$"
      },
      "additionalProperties": {
        "type": [
          "string",
          "integer",
          "number",
          "boolean"
        ]
      },
      "description": "One assignment: a path on the target (at most one hop across a link, per ADR 0005) set to a literal or a params.* / target.* reference."
    },
    "action": {
      "type": "object",
      "required": [
        "target",
        "guard",
        "authority",
        "audit",
        "effects"
      ],
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "$ref": "#/$defs/annotations"
        },
        "target": {
          "$ref": "#/$defs/typeName"
        },
        "parameters": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/memberName"
          },
          "additionalProperties": {
            "$ref": "#/$defs/dataProperty"
          }
        },
        "guard": {
          "$ref": "#/$defs/celExpression"
        },
        "authority": {
          "$ref": "#/$defs/memberName"
        },
        "approval": {
          "type": "object",
          "required": [
            "when",
            "authority"
          ],
          "additionalProperties": false,
          "properties": {
            "when": {
              "$ref": "#/$defs/celExpression"
            },
            "authority": {
              "$ref": "#/$defs/memberName"
            }
          }
        },
        "audit": {
          "enum": [
            "none",
            "standard",
            "mandatory"
          ]
        },
        "effects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/effect"
          }
        }
      }
    },
    "invariant": {
      "type": "object",
      "required": [
        "over",
        "check"
      ],
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "$ref": "#/$defs/annotations"
        },
        "over": {
          "$ref": "#/$defs/typeName"
        },
        "check": {
          "$ref": "#/$defs/celExpression"
        }
      }
    },
    "dataProperty": {
      "allOf": [
        {
          "$ref": "#/$defs/property"
        },
        {
          "not": {
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "const": "state"
              }
            }
          },
          "description": "Lifecycle state is entity-only; parameters and link properties may not declare it."
        }
      ]
    }
  }
}