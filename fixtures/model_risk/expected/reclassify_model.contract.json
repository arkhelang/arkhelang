{
  "arkhe_contract": "0.1",
  "kind": "action",
  "name": "model_risk.reclassify_model",
  "description": "Reclassify a model's purpose and materiality tier outside of production. Writes two enum destinations: purpose (string-valued) and tier (integer-valued).",
  "target": {
    "entity": "model_risk.FinancialModel",
    "keys": [
      "model_id"
    ]
  },
  "parameters": {},
  "guard": {
    "language": "cel",
    "expression": "target.status != \"production\" && target.status != \"retired\"",
    "context": {
      "target": "model_risk.FinancialModel",
      "traversals": [],
      "stdlib": []
    }
  },
  "authority": {
    "role": "model_risk.head_of_model_risk",
    "claims": {
      "groups": "mrm/head"
    }
  },
  "approval": null,
  "audit": {
    "level": "mandatory",
    "event": "model_risk.reclassify_model.v1"
  },
  "effects": [
    {
      "path": "target.purpose",
      "value": "risk",
      "type": "enum",
      "values": [
        "pricing",
        "risk",
        "capital",
        "aml"
      ]
    },
    {
      "path": "target.tier",
      "value": 2,
      "type": "enum",
      "values": [
        1,
        2,
        3
      ]
    }
  ],
  "write_surface": [
    "model_risk.FinancialModel"
  ],
  "refusal": {
    "shape": {
      "refused": true,
      "action": "model_risk.reclassify_model",
      "failed_clause": "string",
      "explanation": "string"
    }
  },
  "provenance": {
    "module": "model_risk",
    "module_version": "0.1.0",
    "arkhe_version": "0.1",
    "source_hash": "sha256:87200786cb3ca109c1e950f24c3c661d7ac65ead5a6efc1b070e9ae7fd039ee2"
  }
}
